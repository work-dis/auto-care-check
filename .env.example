# Database Connection
# Runtime connection. For Supabase on Vercel, prefer the pooled connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autopulse?schema=public"

# Direct connection for Prisma migrations and Studio.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/autopulse?schema=public"

# Application Configuration
PORT=3000
NODE_ENV="development"

# JWT Secret for authentication
JWT_SECRET="autopulse-dev-secret-change-in-production"

# Vercel cron authorization secret
CRON_SECRET="replace-with-a-random-16-char-secret"
