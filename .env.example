# ─── AutoPulse — Environment Variables ───────────────────────────
# Copy to .env and fill in. For Vercel, set these in Dashboard.
#
# Vercel Hobby: PostgreSQL via Neon, no cron, Node.js runtime.
# ──────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# LOCAL (Docker):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autopulse?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/autopulse?schema=public"

# PRODUCTION (Neon on Vercel):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Application ───────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET="autopulse-dev-secret-change-in-production"

# ── Vercel Cron (no-op on Hobby; set for Pro plan) ───────────────
CRON_SECRET="replace-with-a-random-16-char-secret"

# ── Telegram (optional — login widget) ────────────────────────────
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# ── Web Push (VAPID) ──────────────────────────────────────────────
# Generate keys: npm run generate-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BFfCgPmUoGgHL5XojQ1QgYdTmxEGoi9rl2P73CR3iQhpROLdRoZpucCMDFg4SvIeuRnp6mt-8WBT7ZevzybE7Ok"
VAPID_PRIVATE_KEY="1pyBn1n4aaOcD3TZFzZeh1ODT3oCEcCyLRyLeTJ-Jcc"

# ── Cloudinary (optional — image upload) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────────────────────────
# Vercel Dashboard — set these as Environment Variables there:
#   DATABASE_URL, DIRECT_URL, JWT_SECRET
#   CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   NEXT_PUBLIC_VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY
#
# Vercel auto-sets: VERCEL=1, NEXT_PUBLIC_VERCEL_URL
